# Authentication (choose one):
# Option A: Gemini API Key (free tier, 1500 req/day) — preferred for prompt engineering
GEMINI_API_KEY=your-gemini-api-key

# Option B: GCP Service Account (required for Veo video generation)
# Download service account key from GCP Console, save it at app/configs/
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1

# Veo Model
# Options: lite, fast, standard
VEO_MODE=lite

# LLM Model for Prompt Engineering
LLM_MODEL=gemini-1.5-flash-002
